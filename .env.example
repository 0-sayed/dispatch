# Node runtime mode used by Nest services.
NODE_ENV=development

# Pino log level for all Nest services.
LOG_LEVEL=info

# Auth service HTTP port.
AUTH_PORT=3001

# Jobs service HTTP port.
JOBS_PORT=3002

# Products service HTTP port.
PRODUCTS_PORT=3003

# PostgreSQL host port exposed by Docker Compose.
POSTGRES_PORT=15432

# PostgreSQL bootstrap username for local development.
POSTGRES_USER=dispatch

# PostgreSQL bootstrap password for local development only. Replace in local .env.
POSTGRES_PASSWORD=changeme

# PostgreSQL default database created by the container.
POSTGRES_DB=dispatch

# Default database URL used by Drizzle CLI until service-specific migrations exist.
DATABASE_URL=postgres://dispatch:changeme@localhost:15432/dispatch

# Auth service database URL.
AUTH_DATABASE_URL=postgres://dispatch:changeme@localhost:15432/dispatch_auth

# Jobs service database URL.
JOBS_DATABASE_URL=postgres://dispatch:changeme@localhost:15432/dispatch_jobs

# Products service database URL.
PRODUCTS_DATABASE_URL=postgres://dispatch:changeme@localhost:15432/dispatch_products

# Apache Pulsar binary protocol host port exposed by Docker Compose.
PULSAR_PORT=16650

# Apache Pulsar admin HTTP host port exposed by Docker Compose.
PULSAR_ADMIN_PORT=18080

# Apache Pulsar service URL used by producers and consumers.
PULSAR_SERVICE_URL=pulsar://localhost:16650

# Apache Pulsar admin URL used by local inspection tools.
PULSAR_ADMIN_URL=http://localhost:18080

# Local disk directory for uploaded job input files.
UPLOADS_DIR=uploads
