{
  "name": "dispatch",
  "version": "0.1.0",
  "description": "Dispatch is a distributed job-processing engine built with NestJS microservices.",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": "22.14.0",
    "pnpm": "10.26.2"
  },
  "scripts": {
    "lint": "eslint \"**/*.ts\" --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "audit": "pnpm audit --audit-level=high",
    "secrets:scan": "gitleaks detect --redact --source .",
    "postinstall": "GIT_CONFIG_GLOBAL=/dev/null lefthook install",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm knip && pnpm run audit && pnpm build",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.21",
    "@nx/js": "^22.7.2",
    "@nx/nest": "^22.7.2",
    "@nx/node": "^22.7.2",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "25.8.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "knip": "^6.14.1",
    "lefthook": "^2.1.6",
    "nx": "22.7.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
